#include <stdio.h>
#include <string.h>

#definir MÁXIMO 100

// Estrutura do Cliente

struct Cliente {
    int id;
    char nome[50];
    char telefone[20];
}

int main() {
    struct Cliente clientes[MAX];
    int total = 0;
    int opcao = 0;

    enquanto (opcao != 5) {

        printf("\n===== SISTEMA DE CLIENTES =====\n");
        printf("1 - Cadastrar cliente\n");
        printf("2 - Listar clientes\n");
        printf("3 - Buscar cliente\n");
        printf("4 - Excluir cliente\n");
        printf("5 - Sair\n");
        printf("Escolha uma opção: ");

        scanf("%d", &opcao);
        getchar(); // Limpar buffer

        // Cadastro Cliente
        
        se (opcao == 1) {

            se (total < MÁXIMO) {

                clientes[total].id = total + 1;

                printf("Nome: ");
                fgets(clientes[total].nome, 50, stdin);
                clientes[total].nome[strcspn(clientes[total].nome, "\n")] = '\0';

                printf("Telefone: ");
                fgets(clientes[total].telefone, 20, stdin);
                clientes[total].telefone[strcspn(clientes[total].telefone, "\n")] = '\0';

                total++;

                printf("Cliente cadastrado com sucesso!\n");

            } outro {
                printf("Limite de clientes atingidos!\n");
            }
        }

        // Listar Clientes

        senão se (opcao == 2) {

            se (total == 0) {

                printf("Nenhum cliente cadastrado.\n");

            } outro {

                printf("\n--- LISTA DE CLIENTES ---\n");

                para (int i = 0; i < total; i++) {

                    printf("ID: %d\n", cliente[i].id);
                    printf("Nome: %s\n", clientes[i].nome);
                    printf("Telefone: %s\n", clientes[i].telefone);
                    printf("-------------------------\n");
                }
            }
        }

        // Buscar Cliente
       
        senão se (opcao == 3) {

            int idBusca;
            int encontrado = 0;

            printf("Dígito do ID do cliente: ");
            scanf("%d", &idBusca);

            para (int i = 0; i < total; i++) {

                se (clientes[i].id == idBusca) {

                    printf("\nCliente encontrado!\n");
                    printf("ID: %d\n", cliente[i].id);
                    printf("Nome: %s\n", clientes[i].nome);
                    printf("Telefone: %s\n", clientes[i].telefone);

                    encontrado = 1;
                    quebrar;
                }
            }

            se (!encontrado) {
                printf("Cliente não encontrado!\n");
            }
        }

        // Excluir Cliente
        
        senão se (opcao == 4) {

            int idExcluir;
            int encontrado = 0;

            se (total == 0) {

                printf("Não existem clientes cadastrados.\n");

            } outro {

                printf("Digite o ID do cliente que deseja excluir: ");
                scanf("%d", &idExcluir);

                para (int i = 0; i < total; i++) {

                    if (clientes[i].id == idExcluir) {

                        encontrado = 1;

                        // Mova os registros para preencher o espaço
                        para (int j = i; j < total - 1; j++) {

                            clientes[j] = clientes[j + 1];
                        }

                        total--;

                        // Reorganizar os IDs
                        para (int j = 0; j < total; j++) {

                            clientes[j].id = j + 1;
                        }

                        printf("Cliente excluído com sucesso!\n");
                        quebrar;
                    }
                }

                se (!encontrado) {

                    printf("Cliente com ID %d não encontrado.\n", idExcluir);
                }
            }
        }

        // Opção Inválida

        senão se (opcao != 5) {

            printf("Opção invalida! Tente novamente.\n");
        }
    }

    printf("Encerrando o sistema...\n");

    retornar 0;
}
